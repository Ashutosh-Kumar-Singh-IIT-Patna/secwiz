# --- Public (browser) ---------------------------------------------------
# Where the FastAPI backend is reachable from the browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Server-only (never sent to the browser) ----------------------------
# Same backend, but accessed from the Next.js server (api routes).
BACKEND_URL=http://localhost:8000
# Header value for POST /v1/runs/trigger. Must match backend's DEMO_TRIGGER_TOKEN.
DEMO_TRIGGER_TOKEN=changeme
