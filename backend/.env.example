# --- Anakin -------------------------------------------------------------
# Required for Wire / URL Scraper / Agentic Search / Search calls.
ANAKIN_API_KEY=
ANAKIN_BASE_URL=https://api.anakin.io/v1

# --- Gemini judge -------------------------------------------------------
# Optional. When set, every alert-eligible event runs through Gemini for
# intent detection (is this really a vulnerability vs. a tutorial/news?)
# and gets a 2-3 sentence email summary. Leave blank to disable — the
# pipeline falls back to deterministic-only scoring.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-flash-latest
MAX_GEMINI_CALLS_PER_RUN=8
GEMINI_PREFILTER_MIN_SEVERITY=35

# --- Email (SendGrid Web API) -------------------------------------------
# Leave EMAIL_DRY_RUN=true for local demos — alerts are logged, not sent.
# Flip to false plus fill SENDGRID_API_KEY + EMAIL_FROM to actually send.
#
# The key needs the "Mail Send" scope. EMAIL_FROM must be verified in
# your SendGrid account (Single Sender Verification works without owning
# a domain — verify any Gmail address).
EMAIL_DRY_RUN=true
EMAIL_FROM=
SENDGRID_API_KEY=
SENDGRID_API_BASE=https://api.sendgrid.com/v3

# --- Auth ---------------------------------------------------------------
# Required header (X-Demo-Token) for POST /v1/runs/trigger.
DEMO_TRIGGER_TOKEN=changeme

# --- Storage ------------------------------------------------------------
# Path to the JSON-file dummy DB. Relative paths resolve against repo root.
DATA_FILE=backend/data/store.json

# --- HTTP / polling -----------------------------------------------------
HTTP_TIMEOUT_SECONDS=30
ANAKIN_POLL_INTERVAL_SECONDS=3
ANAKIN_POLL_MAX_SECONDS=180
INGEST_CONCURRENCY=5

# --- Scheduler ----------------------------------------------------------
RUN_INTERVAL_MINUTES=60

# --- Caching ------------------------------------------------------------
# How long to cache GET /v1/wire-catalog before re-fetching from Anakin.
WIRE_CATALOG_TTL_SECONDS=86400

# --- Per-run cost caps --------------------------------------------------
# Hard limits per ingest_all() so a single hourly tick can't burn through
# Anakin credits. Bump up for production, drop to 0 to disable a family.
MAX_WIRE_CALLS_PER_RUN=4
MAX_AGENTIC_CALLS_PER_RUN=1
MAX_URL_SCRAPER_BATCHES_PER_RUN=2

# --- Pipeline tuning ----------------------------------------------------
# Sliding window for content-hash dedup in normalize_docs(). Set to 0 to
# disable dedup entirely (every run re-emits every doc — handy for demos).
DEDUP_WINDOW_HOURS=24

# --- Logging ------------------------------------------------------------
LOG_LEVEL=INFO
